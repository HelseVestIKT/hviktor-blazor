{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "pnpm": ">=11.0.0",
    "npm": "please-use-pnpm"
  },
  "scripts": {
    "prepare": "husky",
    "build:dev": "pnpm -r build:dev",
    "build:prod": "pnpm -r build:prod",
    "pack:dev": "node tools/pack-dev.mjs",
    "test-pack:dev": "pnpm -r test-pack",
    "format": "prettier --write \"**/*.{js,ts,mjs,scss,css,html,json,md}\"",
    "generate:metadata": "pnpm -r generate:metadata",
    "generate:html": "pnpm -r generate:html"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "autoprefixer": "10.5.0",
    "cssnano": "8.0.1",
    "glob": "13.0.6",
    "husky": "9.1.7",
    "immutable": "5.1.6",
    "lint-staged": "17.0.7",
    "postcss": "8.5.15",
    "postcss-cli": "11.0.1",
    "postcss-import": "16.1.1",
    "postcss-mixins": "12.1.2",
    "postcss-nested": "7.0.2",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "svgo": "4.0.1"
  },
  "lint-staged": {
    "*.{js,ts,mjs}": "prettier --check",
    "*.{css,scss,html}": "prettier --check",
    "*.{json,md}": "prettier --check"
  }
}
