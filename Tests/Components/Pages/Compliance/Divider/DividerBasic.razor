@page "/component/compliance/divider/basic"
@using Hviktor.Components.Divider

<main data-testid="compliance-container">
    <section aria-label="Basic divider usage" data-testid="divider-basic">
        <h2>Section One</h2>
        <p>Content in the first section.</p>
        <Divider />
        <h2>Section Two</h2>
        <p>Content in the second section.</p>
    </section>

    <section aria-label="Divider between paragraphs" data-testid="divider-paragraphs">
        <p>First paragraph of content.</p>
        <Divider />
        <p>Second paragraph of content.</p>
    </section>
</main>
