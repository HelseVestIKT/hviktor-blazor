@page "/component/compliance/avatar/as-child"
@using Hviktor.Components.Avatar

<main data-testid="compliance-container">
    <section aria-label="Avatar as image">
        <Avatar asChild data-testid="as-anchor">
            <a href="https://www.google.com/search?q=John+Doe" aria-label="View John Doe's profile">
                <img src="/placeholder-avatar.png" alt="placeholder profile picture" aria-hidden="true"/>
            </a>
        </Avatar>
    </section>

    <section aria-label="Avatar as text">
        <Avatar asChild id="as-link" data-testid="as-link">
            <a href="/profile/janesmith" aria-label="View Jane Smith's profile">JS</a>
        </Avatar>
    </section>
</main>
