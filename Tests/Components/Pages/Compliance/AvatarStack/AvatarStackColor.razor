@page "/component/compliance/avatar-stack/color"
@using Hviktor.Components.Avatar
@using Hviktor.Components.AvatarStack

<main data-testid="compliance-container">
    <section aria-label="Accent color avatar stack">
        <AvatarStack color="accent" aria-label="Accent team members" data-testid="accent">
            <Avatar aria-label="Member 1">M1</Avatar>
            <Avatar aria-label="Member 2">M2</Avatar>
        </AvatarStack>
    </section>

    <section aria-label="Neutral color avatar stack">
        <AvatarStack color="neutral" aria-label="Neutral team members" data-testid="neutral">
            <Avatar aria-label="Member 1">M1</Avatar>
            <Avatar aria-label="Member 2">M2</Avatar>
        </AvatarStack>
    </section>

    <section aria-label="Info color avatar stack">
        <AvatarStack color="info" aria-label="Info team members" data-testid="info">
            <Avatar aria-label="Member 1">M1</Avatar>
            <Avatar aria-label="Member 2">M2</Avatar>
        </AvatarStack>
    </section>

    <section aria-label="Success color avatar stack">
        <AvatarStack color="success" aria-label="Success team members" data-testid="success">
            <Avatar aria-label="Member 1">M1</Avatar>
            <Avatar aria-label="Member 2">M2</Avatar>
        </AvatarStack>
    </section>

    <section aria-label="Warning color avatar stack">
        <AvatarStack color="warning" aria-label="Warning team members" data-testid="warning">
            <Avatar aria-label="Member 1">M1</Avatar>
            <Avatar aria-label="Member 2">M2</Avatar>
        </AvatarStack>
    </section>

    <section aria-label="Danger color avatar stack">
        <AvatarStack color="danger" aria-label="Danger team members" data-testid="danger">
            <Avatar aria-label="Member 1">M1</Avatar>
            <Avatar aria-label="Member 2">M2</Avatar>
        </AvatarStack>
    </section>
</main>
