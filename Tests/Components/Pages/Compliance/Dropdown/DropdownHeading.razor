                    <Dropdown.Item>
                        <Button>Item</Button>
                    </Dropdown.Item>
                </Dropdown.List>
            </Dropdown>
        </Dropdown.TriggerContext>
    </section>

    <section aria-label="Dropdown with heading level 4" data-testid="heading-level-4">
