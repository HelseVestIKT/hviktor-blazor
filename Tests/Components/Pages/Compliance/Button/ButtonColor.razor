@page "/component/compliance/button/color"
@using Hviktor.Abstractions.Enums.Attributes
@using Hviktor.Components.Button

<main data-testid="compliance-container">
    <section aria-label="Accent color">
        <Button Color="@Color.Accent" data-testid="accent">Accent</Button>
    </section>

    <section aria-label="Neutral color">
        <Button Color="@Color.Neutral" data-testid="neutral">Neutral</Button>
    </section>

    <section aria-label="Brand1 color">
        <Button Color="@Color.Brand1" data-testid="brand1">Brand1</Button>
    </section>

    <section aria-label="Brand2 color">
        <Button Color="@Color.Brand2" data-testid="brand2">Brand2</Button>
    </section>

    <section aria-label="Brand3 color">
        <Button Color="@Color.Brand3" data-testid="brand3">Brand3</Button>
    </section>

    <section aria-label="Success color">
        <Button Color="@Color.Success" data-testid="success">Success</Button>
    </section>

    <section aria-label="Danger color">
        <Button Color="@Color.Danger" data-testid="danger">Danger</Button>
    </section>

    <section aria-label="Info color">
        <Button Color="@Color.Info" data-testid="info">Info</Button>
    </section>

    <section aria-label="Warning color">
        <Button Color="@Color.Warning" data-testid="warning">Warning</Button>
    </section>
</main>
