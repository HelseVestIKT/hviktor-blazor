@page "/component/compliance/errorsummary/basic"
@using Hviktor.Components.ErrorSummary

<main data-testid="compliance-container">
    <section aria-label="Basic error summary" data-testid="basic">
        <ErrorSummary>
            <ErrorSummary.Heading>Errors in form</ErrorSummary.Heading>
            <ErrorSummary.List>
                <ErrorSummary.Item>
                    <ErrorSummary.Link Href="#field1">First name is required</ErrorSummary.Link>
                </ErrorSummary.Item>
                <ErrorSummary.Item>
                    <ErrorSummary.Link Href="#field2">Email is invalid</ErrorSummary.Link>
                </ErrorSummary.Item>
            </ErrorSummary.List>
        </ErrorSummary>
    </section>

    <section aria-label="Error summary with single error" data-testid="single-error">
        <ErrorSummary>
            <ErrorSummary.Heading>Validation error</ErrorSummary.Heading>
            <ErrorSummary.List>
                <ErrorSummary.Item>
                    <ErrorSummary.Link Href="#password">Password must be at least 8 characters</ErrorSummary.Link>
                </ErrorSummary.Item>
            </ErrorSummary.List>
        </ErrorSummary>
    </section>
</main>
