{
  "name": "documentation",
  "version": "1.0.0",
  "author": "Helse Vest IKT",
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ],
  "scripts": {
    "build": "node build.mjs --configuration Debug",
    "build:dev": "node build.mjs --configuration Debug",
    "build:prod": "node build.mjs --configuration Release",
    "compile-sass": "sass --load-path=node_modules \"wwwroot/styles/index.scss\" \"wwwroot/styles/index.css\" --no-source-map --style=compressed",
    "compile-postcss": "postcss \"wwwroot/styles/tailwind.css\" -o \"wwwroot/styles/tailwind.min.css\"",
    "generate:metadata": "node generate-metadata.mjs",
    "generate:html": "node generate-html-entries.mjs"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "sass": "1.99.0",
    "sass-embedded": "1.99.0",
    "tailwindcss": "4.3.0"
  }
}
