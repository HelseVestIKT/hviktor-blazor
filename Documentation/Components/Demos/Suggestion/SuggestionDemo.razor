@using Hviktor.Components.Field
@using Hviktor.Components.Suggestion
@using Hviktor.Components.Typography

@code {
    private readonly List<string> DATA_PLACES =
    [
        "Sogndal",
        "Oslo",
        "Brønnøysund",
        "Stavanger",
        "Trondheim",
        "Bergen",
        "Lillestrøm",
    ];
}

<Field>
    <Label>Select a destination</Label>
    <Suggestion>
        <Suggestion.Input/>
        <Suggestion.Clear/>
        <Suggestion.List>
            <Suggestion.Empty>
                No results found
            </Suggestion.Empty>
            @foreach (var place in DATA_PLACES)
            {
                <Suggestion.Option @key="@place" label="@place" value="@place">
                    @place
                    <div>Municipality</div>
                </Suggestion.Option>
            }
        </Suggestion.List>
    </Suggestion>
</Field>
