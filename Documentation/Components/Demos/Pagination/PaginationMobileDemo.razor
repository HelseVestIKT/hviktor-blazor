@using Hviktor.Components.Pagination

<Pagination aria-label="Pagination menu">
    <Pagination.List>
        <Pagination.Item>
            <Pagination.Button
                aria-label="Previous page"
                variant="tertiary"
            />
        </Pagination.Item>

        <Pagination.Item>
            <Pagination.Button aria-label="Page 2" variant="tertiary">
                2
            </Pagination.Button>
        </Pagination.Item>

        <Pagination.Item>
            <Pagination.Button aria-label="Page 3">3</Pagination.Button>
        </Pagination.Item>

        <Pagination.Item>
            <Pagination.Button aria-label="Page 4" variant="tertiary">
                4
            </Pagination.Button>
        </Pagination.Item>

        <Pagination.Item>
            <Pagination.Button aria-label="Next page" variant="tertiary"/>
        </Pagination.Item>
    </Pagination.List>
</Pagination>