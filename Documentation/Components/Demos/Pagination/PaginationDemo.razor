@using Hviktor.Components.Pagination

<Pagination aria-label="Pagination menu">
    <Pagination.List>
        <Pagination.Item>
            <Pagination.Button aria-label="Previous page" variant="tertiary">
                Previous
            </Pagination.Button>
        </Pagination.Item>

        <Pagination.Item>
            <Pagination.Button aria-label="Page 1" variant="tertiary">
                1
            </Pagination.Button>
        </Pagination.Item>

        <Pagination.Item>
            <Pagination.Button aria-label="Page 2" variant="primary">
                2
            </Pagination.Button>
        </Pagination.Item>

        <Pagination.Item/>

        <Pagination.Item>
            <Pagination.Button aria-label="Page 9" variant="tertiary">
                9
            </Pagination.Button>
        </Pagination.Item>

        <Pagination.Item>
            <Pagination.Button aria-label="Page 10" variant="tertiary">
                10
            </Pagination.Button>
        </Pagination.Item>

        <Pagination.Item>
            <Pagination.Button aria-label="Next page" variant="tertiary">
                Next
            </Pagination.Button>
        </Pagination.Item>
    </Pagination.List>
</Pagination>