@using Hviktor.Components.Code

@code {

    private const string Src = """
                               .button {
                                   display: inline-flex;
                                   align-items: center;
                                   gap: 0.5rem;
                                   padding: 0.75rem 1.25rem;
                                   border-radius: var(--ds-border-radius-md);
                                   background-color: var(--ds-color-accent-base-default);
                                   color: var(--ds-color-accent-text-on-action);
                                   font-size: 1rem;
                                   font-weight: 500;
                                   cursor: pointer;
                                   transition: background-color 0.2s ease;
                                   
                                   &:focus-visible {
                                       outline: 2px solid var(--ds-color-focus-outer);
                                       outline-offset: 2px;
                                   }
                               }

                               .button:hover {
                                   background-color: var(--ds-color-accent-base-hover);
                               }

                               .button[disabled] {
                                   background-color: var(--ds-color-neutral-base-disabled);
                                   color: var(--ds-color-neutral-text-disabled);
                                   cursor: not-allowed;
                               }
                               
                               button[data-command='close'] {
                                  background-color: transparent;
                                  color: var(--ds-color-neutral-text-default);
                               }

                               @media (prefers-reduced-motion: reduce) {
                                   .button {
                                       transition: none;
                                   }
                               }
                               """;

}

<CodeBlock Language="css" Code="@Src" class="w-full"/>