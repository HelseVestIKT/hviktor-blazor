@using Hviktor.Abstractions.Enums.Attributes
@using Hviktor.Components.Button
@using Hviktor.Components.Loader
@using Hviktor.Components.Typography

@implements IDisposable

@code {
    private Loader loaderRef = null!;
    private CancellationTokenSource cts = new();

    private async Task OpenAndCloseAfterFiveSecondsAsync()
    {
        loaderRef.Open();
        await Task.Delay(5000, cts.Token);
        loaderRef.Close();
    }

    public void Dispose()
    {
        cts.Cancel();
        cts.Dispose();
    }
}

<Loader @ref="@loaderRef" color="accent" position="@Position.Center" modal>
    <div>
        <Heading level="2">Authorizing</Heading>
        <Paragraph>
            Please wait while we authorize the app.
        </Paragraph>
    </div>
</Loader>

<Button @onclick="@OpenAndCloseAfterFiveSecondsAsync">
    Open and close after 5 seconds
</Button>