<?xml version="1.0" encoding="utf-8"?>

<configuration>
    <packageSources>
        <clear />
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
        <add key="HelseVestIKT" value="https://nuget.pkg.github.com/HelseVestIKT/index.json" />
    </packageSources>

    <packageSourceMapping>
        <packageSource key="nuget.org">
            <package pattern="*" />
        </packageSource>
        <packageSource key="HelseVestIKT">
            <package pattern="Hviktor" />
            <package pattern="Hviktor.*" />
        </packageSource>
    </packageSourceMapping>

    <packageSourceCredentials>
        <HelseVestIKT>
            <add key="Username" value="%NUGET_USER%" />
            <add key="ClearTextPassword" value="%NUGET_TOKEN%" />
        </HelseVestIKT>
    </packageSourceCredentials>
</configuration>